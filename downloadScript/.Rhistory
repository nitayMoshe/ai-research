library(curatedMetagenomicData)
download_and_save <- function(study_name) {
# בניית שם המחקר המלא כפי שהספרייה דורשת
dataset_id <- paste0(study_name, ".metaphlan_bugs_list.stool")
print(paste("Downloading:", dataset_id))
# הורדת המחקר (dryrun=FALSE אומר לו להוריד באמת)
tse <- curatedMetagenomicData(dataset_id, dryrun = FALSE)
# חילוץ הנתונים
# colData = מטא-דאטה (מידע על הנבדקים)
# assay = טבלת הפיצ'רים (החיידקים)
metadata <- as.data.frame(colData(tse))
features <- as.data.frame(assay(tse))
# טרנספוזיציה (הופכים שורות לעמודות) כדי שיהיה נוח ל-AI
# ב-R, t() עושה transpose למטריצה/דאטה-פרייים
features_t <- t(features)
# הוספת עמודת שם המחקר למטא-דאטה
metadata$study_name <- study_name
# שמירה ל-CSV
write.csv(metadata, paste0(study_name, "_metadata.csv"), row.names = TRUE)
write.csv(features_t, paste0(study_name, "_features.csv"), row.names = TRUE)
print("Done! Files saved successfully.")
}
# הרצה לדוגמה (אפשר לשנות לשם אחר)
download_and_save("FengQ_2015")
